<Window x:Class="Nail_nail.RecordInformation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Nail_nail"
        mc:Ignorable="d"
        Title="RecordInformation" Height="400" Width="350">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Button x:Name="BackBtn" Content="Назад" Width="55" Height="20" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,10" Grid.Row="0" Click="BackBtn_Click"/>

        <StackPanel Orientation="Vertical" Margin="10,5" Grid.Row="1">
            <TextBlock Text="Мастер: ФИО" FontSize="14" Margin="0,0,0,5"/>
            <TextBlock Text="Время: время" FontSize="14" Margin="0,0,0,5"/>
            <TextBlock Text="Выберите услуги:" FontSize="14" HorizontalAlignment="Center"/>
            <ListBox x:Name="Servises_LB" ItemsSource="{Binding услуги}" MaxHeight="150" ScrollViewer.HorizontalScrollBarVisibility="Hidden" BorderThickness="0" Padding="0" Margin="0,0,0,5" >
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <CheckBox x:Name="ServiceChoice" Content="{Binding название_услуги}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
            <TextBlock Text="Выберите способ оплаты:" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <RadioButton x:Name="sbp_method" Content="СБП" GroupName="PaymentChoice" VerticalContentAlignment="Center" Margin="0,0,0,5"/>
            <RadioButton x:Name="mir_method" Content="Карта МИР" GroupName="PaymentChoice" VerticalContentAlignment="Center" Margin="0,0,0,5"/>
            <Button x:Name="Accept" Content="Подтвердить запись" Click="Accept_Click" />
        </StackPanel>
    </Grid>
</Window>
