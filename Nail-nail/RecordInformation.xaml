<Window x:Class="Nail_nail.RecordInformation"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Nail_nail"
        mc:Ignorable="d"
        Title="RecordInformation" Height="400" Width="350">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Button x:Name="BackBtn" Content="Назад" Width="55" Height="20" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,0" Grid.Row="0" Click="BackBtn_Click"/>

        <StackPanel Orientation="Vertical" Margin="10,5" Grid.Row="1">
            <Button x:Name="Accept" Content="Подтвердить запись"/>
        </StackPanel>
    </Grid>
</Window>
