<Page x:Class="Nail_nail.Pages.Authorization"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Nail_nail.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="Authorization">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="24*"/>
            <ColumnDefinition Width="32*"/>
            <ColumnDefinition Width="24*"/>
        </Grid.ColumnDefinitions>

        <Button x:Name="BackBtn" Content="Назад" Width="55" Height="20" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Click="BackBtn_Click"/>

        <!-- Авторизация и регистрация-->
        <Grid x:Name="AuthorizationAndRegistrationGrid" Width="300" Height="350" Visibility="Visible" Grid.Column="1">
            <StackPanel Orientation="Vertical">
                <!-- Логин -->
                <TextBlock Text="Логин" FontSize="20" Height="30" Foreground="Gray" Margin="0,0,0,10"/>
                <TextBox x:Name="LoginTBox" Text="" FontSize="20" Height="30" Margin="0,0,0,10"/>
                <!-- Пароль -->
                <TextBlock Text="Пароль" FontSize="20" Height="30" Foreground="Gray" Margin="0,0,0,10"/>
                <PasswordBox x:Name="PasswordTBox" PasswordChar="*" FontSize="20" Height="30" Margin="0,0,0,10"/>
                <!-- Имя -->
                <StackPanel x:Name="FIO_StackPanel"  Visibility="Collapsed">
                    <TextBlock Text="ФИО" FontSize="20" Height="30" Foreground="Gray" Margin="0,0,0,10"/>
                    <TextBox x:Name="NameTBox" FontSize="20" Height="30" Margin="0,0,0,10"/>
                </StackPanel>
                <!-- Телефон -->
                <StackPanel x:Name="Phone_StackPanel" Visibility="Collapsed">
                    <TextBlock Text="Телефон" FontSize="20" Height="30" Foreground="Gray" Margin="0,0,0,10"/>
                    <TextBox x:Name="PhoneTBox" FontSize="20" Height="30" Margin="0,0,0,10" PreviewTextInput="NumberValidationTextBox"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock x:Name="ChangeTBlock"  Text="Если у вас нет аккаунта: " Foreground="Gray" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    <Button x:Name="ChangeBtn" Content="зарегистрироваться" Width="auto" VerticalContentAlignment="Center" Foreground="DarkBlue"  Background="Transparent" BorderBrush="Transparent" Click="ChangeBtn_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Button x:Name="RegOrLogBtn" Content="Войти" Grid.Column="1" Height="30" Width="135" VerticalAlignment="Bottom" FontSize="14" Margin="0,0,0,20" Click="RegOrLogBtn_Click"/>
    </Grid>
</Page>
