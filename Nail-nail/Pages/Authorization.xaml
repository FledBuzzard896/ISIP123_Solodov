<Page x:Class="Nail_nail.Pages.Authorization"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Nail_nail.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="Authorization">

    <Grid>
        <!-- Авторизация -->
        <Grid x:Name="AuthorizationGrid" Width="300" Height="350" Visibility="Visible">
            <StackPanel Orientation="Vertical">
                <!-- Логин -->
                <TextBlock Text="Логин" FontSize="20" Height="30" Foreground="Gray" Margin="0,0,0,10"/>
                <TextBox x:Name="LoginTBox" Text="" FontSize="20" Height="30" Margin="0,0,0,10"/>
                <!-- Пароль -->
                <TextBlock Text="Пароль" FontSize="20" Height="30" Foreground="Gray" Margin="0,0,0,10"/>
                <PasswordBox x:Name="PasswordTBox" PasswordChar="*" FontSize="20" Height="30" Margin="0,0,0,10"/>

                <TextBlock Text="Если у вас уже есть аккаунт" Foreground="Gray" HorizontalAlignment="Center"/>
                <Button x:Name="ChangeToRegistrationBtn" Content=""/>
            </StackPanel>
        </Grid>
        <!-- Регистрация -->
        <Grid x:Name="RegistrationGrid" Width="300" Height="350" Visibility="Collapsed">

        </Grid>
    </Grid>
</Page>
