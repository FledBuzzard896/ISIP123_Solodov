<Page x:Class="Nail_nail.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Nail_nail.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="MainPage">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="50*"/>
            <RowDefinition Height="450*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="Shop" Content="Магазин" Width="70" Height="20" Margin="0,0,10,0" Click="Shop_ButtonClick"/>
            <Button x:Name="AccountLogIn" Content="Войти" Width="70" Height="20" Visibility="Visible" Click="Account_ButtonClick"/>
            <Button x:Name="Account" Width="30" Height="30" Visibility="Collapsed" Click="Account_ButtonClick">
                <Image Source="/Images/incognita.png"/>
            </Button>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <ListBox x:Name="ListOfMasters" Grid.Row="1" Margin="5" ItemsSource="{Binding Path=ListOfMasters}" ScrollViewer.HorizontalScrollBarVisibility="Hidden" BorderThickness="0" Padding="0" >
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5" Orientation="Horizontal">
                            <!-- Иконка -->
                            <Image x:Name="IncognitaImage" Source="/Images/incognita.png" Width="125" Height="125" Margin="0,0,15,0"/>
                            <!-- Имя -->
                            <TextBlock x:Name="NameTB" Text="{Binding Name}" FontSize="14" Width="150" Margin="0,0,15,0"/>
                            <!-- Услуги -->
                            <StackPanel Orientation="Vertical" Margin="0,0,15,0">
                                <TextBlock Text="Услуги" Height="20"/>
                                <ScrollViewer MaxHeight="100" Margin="0,5,0,0">
                                    <TextBlock x:Name="ServicesTB" Text="{Binding Services}" FontSize="10" TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </StackPanel>
                            <!-- Кнопка записи -->
                            <Button x:Name="SignUpBtn" Content="Записаться" Width="100" Height="35" Click="SignUp_ButtonClick"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
        </StackPanel>
    </Grid>
</Page>
