<Page x:Class="Nail_nail.Pages.RecordPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Nail_nail.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="RecordPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="15*"/>
            <RowDefinition Height="135*"/>
        </Grid.RowDefinitions>

        <Button x:Name="BackBtn" Content="Назад" Width="55" Height="20" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,0" Click="BackBtn_Click"/>
        <TextBlock Text="МАСТЕР:" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>

        <StackPanel Grid.Row="1" Margin="10">
            <TextBlock Text="Услуги: " FontSize="14"/>
            <ListBox x:Name="ListOfMasters" Grid.Row="1" Margin="0,10,0,10" ItemsSource="{Binding Path=ListOfMasters}" ScrollViewer.HorizontalScrollBarVisibility="Hidden" BorderThickness="0" Padding="0" >
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5" Orientation="Vertical">
                            <TextBlock Text="{Binding время}" FontSize="14" HorizontalAlignment="Center"/>
                            <!-- Кнопка записи -->
                            <Button x:Name="SignUp" Content="Записаться" Width="75" Height="20" FontSize="14" HorizontalAlignment="Center" Click="SignUp_Click"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
        </StackPanel>
    </Grid>
</Page>
