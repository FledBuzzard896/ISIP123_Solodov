<Page x:Class="Nail_nail.Pages.Account"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Nail_nail.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="Account">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Профиль -->
        <Grid Margin="10,10,5,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="3*"/>
            </Grid.RowDefinitions>

            <Image Source="/Images/incognita.png" Grid.Row="0"/>
            <StackPanel Orientation="Vertical" Margin="0,10,0,0" Grid.Row="1">
                <TextBlock Text="Имя: " Margin="0,0,0,10" FontSize="14"/>
                <TextBlock Text="{Binding FullName}" Margin="0,0,0,10" FontSize="14"/>
                <TextBlock Text="Телефон: " Margin="0,0,0,10" FontSize="14"/>
                <TextBlock Text="{Binding PhoneNumber}" Margin="0,0,0,10" FontSize="14"/>
            </StackPanel>
        </Grid>
        
        <!-- История -->
        <Grid Margin="5,10,10,10" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="5,0,5,0">
                <TextBlock Text="История заказов" FontSize="14" Margin="0,0,0,10"/>
                <ListBox x:Name="OrderHistory" Height="auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5">
                                <Button x:Name="OneOrder" Content="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Margin="5,0,5,0">
                <TextBlock Text="История заказов" FontSize="14" Margin="0,0,0,10"/>
                <ListBox x:Name="RecordHistory" Height="auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5">
                                <Button x:Name="OneRecord" Content="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
