<Window x:Class="ISIP123_Solodov_WPF.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ISIP123_Solodov_WPF"
        mc:Ignorable="d"
        Title="SettingsWindow" Height="300" Width="250">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="31*"/>
            <RowDefinition Height="31*"/>
            <RowDefinition Height="31*"/>
            <RowDefinition Height="31*"/>
            <RowDefinition Height="80*"/>
            <RowDefinition Height="80*"/>
        </Grid.RowDefinitions>

        <Button x:Name="white" Content="Белый" Width="100" Height="20" Grid.Row="0" Click="white_Click"/>
        <Button x:Name="blue" Content="Синий" Width="100" Height="20" Grid.Row="1" Click="blue_Click"/>
        <Button x:Name="red" Content="Красный" Width="100" Height="20" Grid.Row="2" Click="red_Click"/>
        <Button x:Name="green" Content="Зеленый" Width="100" Height="20" Grid.Row="3" Click="green_Click"/>

        <Slider x:Name="WidthSlider"
                Minimum="100"
                Maximum="1000"
                Value="250"
                TickFrequency="1" 
                IsSnapToTickEnabled="True"
                ValueChanged="Slider_ValueChanged"
                Grid.Row="4"
                VerticalAlignment="Center"/>

        <Slider x:Name="HeightSlider"
                Minimum="100"
                Maximum="1000"
                Value="300"
                TickFrequency="1" 
                IsSnapToTickEnabled="True"
                ValueChanged="another_Slider_ValueChanged"
                Grid.Row="5"
                VerticalAlignment="Center"/>
    </Grid>
</Window>
