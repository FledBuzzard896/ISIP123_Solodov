<Window x:Class="ISIP123_Solodov_WPF.RegOrLog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ISIP123_Solodov_WPF"
        mc:Ignorable="d"
        Title="RegOrLog" Height="175" Width="200">
    <Grid>
        <StackPanel Orientation="Vertical">
            <Button x:Name="back" Content="Назад" Width="30" Height="15" FontSize="8" HorizontalAlignment="Left" Margin="5,5,0,0" Click="back_Click"/>
            <TextBlock Text="Войти или зарегистрироваться?" Height="20" HorizontalAlignment="Center" Margin="0,20,0,0"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                <Button x:Name="autho" Content="Войти" Margin="0,0,10,0" Height="20" Click="autho_Click"/>
                <Button x:Name="registr" Content="Зарегистрироваться" Height="20" Click="registr_Click"/>
            </StackPanel>
        </StackPanel>
        
    </Grid>
</Window>
