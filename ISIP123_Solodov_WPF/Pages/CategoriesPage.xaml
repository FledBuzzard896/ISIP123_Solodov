<Page x:Class="ISIP123_Solodov_WPF.Pages.CategoriesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ISIP123_Solodov_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="CategoriesPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <StackPanel Margin="0,5,0,5" Grid.Row="0">
            <TextBlock Text="Приветсвуем вас в нашем телемагазине бытовой техники «Светофор»" FontSize="18" Height="auto" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            <TextBlock Text="Выберите категорию товара, с которого хотите начать свою ШЕДЕВРО-СБОРКУ:" FontSize="16" Height="auto" HorizontalAlignment="Center" TextWrapping="Wrap" Margin="0,15,0,0"/>
        </StackPanel>
        <Grid Grid.Row="1" Margin="15">
            <ListBox x:Name="Categories_LB" ItemsSource="{Binding Path=categories}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Height="auto" Width="auto" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="10,0,10,10">
                            <Button Content="{Binding}" Height="30" Width="150" Click="Category_Click"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
        </Grid>
        <Grid Grid.Row="2" Margin="15,5">
            <ListBox x:Name="SborkaItems_LB" ItemsSource="{Binding Path=sborochka_items}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Height="auto" Width="auto" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="10,0,10,10" Orientation="Vertical">
                            <Image Source="{Binding image}" Width="100" Height="100"/>
                            <TextBlock Text="{Binding name}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
        </Grid>
        <StackPanel Orientation="Horizontal"  Grid.Row="3" Margin="15,5" HorizontalAlignment="Center">
            <Button x:Name="SaveSborkaBtn" Content="Сохранить сборочку" Click="SaveSborkaBtn_Click" Width="200" Margin="0,0,15,0"/>
            <Button x:Name="ShowHistoryBtn" Content="Показать сохранённые сборки" Click="ShowHistoryBtn_Click" Width="200"/>
        </StackPanel>
    </Grid>
</Page>
