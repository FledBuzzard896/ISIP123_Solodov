<Page x:Class="ISIP123_Solodov_WPF.Pages.HistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ISIP123_Solodov_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="HistoryPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid Grid.Row="0" Margin="0,15,0,0" >
            <TextBlock Text="Сборочки:" HorizontalAlignment="Center" FontSize="18"/>
            <Button x:Name="goback" Content="Назад" Width="75" Height="20" HorizontalAlignment="Left" Margin="15,0,0,0" Click="goback_Click"/>
        </Grid>

        <ListBox Grid.Row="1" x:Name="History_LB" Margin="15" ItemsSource="{Binding Path=ItemsHistory}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Height="auto" Width="auto" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" MouseDoubleClick="mouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="10" Orientation="Vertical">
                        <TextBlock Text="{Binding id, StringFormat='ID: {0}'}"/>
                        <TextBlock Text="{Binding name, StringFormat='Название: {0}'}"/>
                        <TextBlock Text="{Binding author, StringFormat='Автор: {0}'}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="1" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
        
    </Grid>
</Page>
