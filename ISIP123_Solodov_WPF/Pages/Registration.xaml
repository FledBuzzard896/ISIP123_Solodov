<Page x:Class="ISIP123_Solodov_WPF.Pages.Registration"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ISIP123_Solodov_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="Registration">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Vertical" Margin="10">
            <TextBlock Text="ФильмоПоиск" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="Регестрируемся - не стесняемся" HorizontalAlignment="Center" Margin="0,0,0,5"/>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,5">
                <TextBlock Text="Введите логин: "/>
                <TextBox x:Name="login" Text="" Width="200" Margin="50,0,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,5">
                <TextBlock Text="Введите пароль: "/>
                <TextBox x:Name="password" Text="" Width="200" Margin="43,0,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,5">
                <TextBlock Text="Повторите пароль: "/>
                <TextBox x:Name="password_2" Text="" Width="200" Margin="28,0,0,0" TextWrapping="Wrap"/>
            </StackPanel>
            
            <TextBlock Text="Введите полное ФИО (Иванов Иван Иванович):" Margin="0,0,0,5"/>
            <TextBox x:Name="fio" Text="" Width="200" Margin="0,0,0,5" TextWrapping="Wrap"/>
            <TextBlock Text="Выберите вашу дату рождения: " Margin="0,0,0,5"/>
            <Calendar x:Name="birthday"/>

            <StackPanel Margin="0,15,0,0" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="back" Content="Назад" Width="150" Margin="0,0,15,0" Click="back_Click"/>
                <Button x:Name="enterInfo" Content="Зарегистрироваться" Width="150" Click="enterInfo_Click"/>
            </StackPanel>
        </StackPanel>

        
        
    </Grid>
</Page>
