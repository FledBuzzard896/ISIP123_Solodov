<Page x:Class="ISIP123_Solodov_WPF.Pages.Page4_Credit"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ISIP123_Solodov_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="400"
      Title="Page4_Credit">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="41*"/>
            <RowDefinition Height="52*"/>
            <RowDefinition Height="38*"/>
            <RowDefinition Height="38*"/>
            <RowDefinition Height="38*"/>
            <RowDefinition Height="195*"/>
            <RowDefinition Height="48*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <TextBlock Margin="0,20,0,0" FontSize="16" Text="Салон Chevrolet 1964-1970" Grid.Row="0" TextAlignment="Center" Grid.ColumnSpan="2"/>
        <TextBlock Margin="20,10,0,0" FontSize="14" FontStyle="Italic" Text="В нашем салоне оплата услуг предоставляется нашим спонсором АО «ФПИбанк» путем оформления автокредита" TextWrapping="Wrap" Grid.ColumnSpan="2" Grid.Row="1"/>
        <StackPanel Margin="20,0,0,0" Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" VerticalAlignment="Center" Height="20">
            <TextBlock FontSize="14" Text="Процент первоначального взноса:" TextWrapping="Wrap"/>
            <TextBox x:Name="Procent" Margin="10,0,0,0" FontSize="14" Text="" Height="20" Width="100" TextChanged="Procent_TextChanged" PreviewTextInput="TextBox_OnPreviewTextInput"/>
        </StackPanel>
        <StackPanel Margin="20,0,0,0" Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" VerticalAlignment="Center" Height="20">
            <TextBlock FontSize="14" Text="Срок кредита в месяцах:" TextWrapping="Wrap"/>
            <TextBox x:Name="Srok" Margin="76,0,0,0" FontSize="14" Text="" Height="20" Width="100" TextChanged="Srok_TextChanged" PreviewTextInput="TextBox_OnPreviewTextInput"/>
        </StackPanel>
        <TextBlock Margin="0,10,0,0" FontSize="14" Text="Рассчетные данные:" TextAlignment="Center" Grid.Row="4" Grid.ColumnSpan="2"/>
        <StackPanel Margin="20,10,0,0" Grid.Row="5" Grid.ColumnSpan="2" Grid.RowSpan="2">
            <TextBlock x:Name="SumOfFirstPayment" FontSize="14" Text="Сумма первоначального взноса: "/>
            <TextBlock x:Name="CreditSum" Margin="0,10,0,0" FontSize="14" Text="Сумма, берущаяся в кредит: "/>
            <TextBlock x:Name="Payment" Margin="0,10,0,0" FontSize="14" Text="Ориентировочный ежемесячный платёж: "/>
        </StackPanel>
        <Button x:Name="ToBack" FontSize="14" Content="Назад" Height="35" Width="150" Grid.Row="6" Grid.Column="0" Click="ToBack_Click"/>
        <Button x:Name="ToNext" FontSize="14" Content="Завершить оплату" Height="35" Width="150" Grid.Row="6" Grid.Column="1" Click="ToNext_Click"/>
    </Grid>
</Page>
