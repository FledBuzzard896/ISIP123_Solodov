<Page x:Class="ISIP123_Solodov_WPF.Pages.PaymentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ISIP123_Solodov_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PaymentPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="23*"/>
        </Grid.RowDefinitions>
        <Button x:Name="back_btn" Content="Назад" Width="80" Height="20" HorizontalAlignment="Right" Margin="0,0,25,0" Click="back_btn_Click"/>
        <TextBlock Text="Чек:" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Grid.Row="0"/>
        <StackPanel Grid.Row="1" Margin="25">
            <TextBlock x:Name="name" Text="Фильм: " FontSize="16"/>
            <TextBlock x:Name="day" Text="День: " FontSize="16"/>
            <TextBlock x:Name="time" Text="Время: " FontSize="16"/>
            <TextBlock x:Name="hall"  Text="Зал: " FontSize="16"/>
            <TextBlock x:Name="type" Text="Тип: " FontSize="16"/>
            <TextBlock x:Name="seats" Text="Место(а): " FontSize="16"/>
            <TextBlock x:Name="price" Text="Цена:" FontSize="16"/>
            <Button x:Name="pay" Content="Оплатить" Width="150" Height="20" Margin="0,100,0,0" Click="pay_Click"/>
        </StackPanel>

    </Grid>
</Page>
