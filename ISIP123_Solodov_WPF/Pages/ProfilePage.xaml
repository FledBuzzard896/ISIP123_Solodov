<Page x:Class="ISIP123_Solodov_WPF.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ISIP123_Solodov_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="ProfilePage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="7*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="Ваш мега крутой профиль" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" Grid.ColumnSpan="2" />
        <StackPanel Margin="5" Grid.Column="0">
            <Image Source="/Image/ava.png" Width="150" Height="150" Margin="0,40,0,0"/>
            <TextBlock x:Name="name" Text="" Margin="0,25,0,3" HorizontalAlignment="Left" FontSize="14"/>
            <TextBlock Text="Имя пользователя" FontSize="10" Foreground="DarkGray"/>
            <TextBlock x:Name="birthday" Text="" Margin="0,5,0,3" HorizontalAlignment="Left" FontSize="14"/>
            <TextBlock Text="Дата рождения" FontSize="10" Foreground="DarkGray"/>
            <TextBlock x:Name="login" Text="" Margin="0,5,0,3" HorizontalAlignment="Left" FontSize="14"/>
            <TextBlock Text="Логин" FontSize="10" Foreground="DarkGray"/>
            <TextBlock x:Name="password" Text="" Margin="0,5,0,3" HorizontalAlignment="Left" FontSize="14"/>
            <TextBlock Text="Пароль" FontSize="10" Foreground="DarkGray"/>
            <Button x:Name="back_btn" Content="На главную" Width="100" Height="20" Margin="0,15,0,0" Click="back_btn_Click"/>
        </StackPanel>
        <TextBlock Text="История покупки билетов:" FontSize="16" FontWeight="Bold" FontStyle="Italic" HorizontalAlignment="Center" Margin="5,40,5,5" Grid.Column="1"/>
        
        <ListBox x:Name="History_LB" ItemsSource="{Binding Path=History}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Height="auto" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="1" Margin="20">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="10,0,10,10">
                        <TextBlock Text="{Binding ID, StringFormat='Айди билета: {0}'}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
    </Grid>
</Page>
