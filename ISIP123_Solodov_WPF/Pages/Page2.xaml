<Page x:Class="ISIP123_Solodov_WPF.Pages.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ISIP123_Solodov_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page2">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="7*"/>
            <RowDefinition Height="68*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" >
            <Button x:Name="red" Width="100" Height="30" Background="Red" Click="red_Click"/>
            <Button x:Name="green" Width="100" Height="30" Background="Green" Margin="20,0,20,0" Click="green_Click"/>
            <Button x:Name="blue" Width="100" Height="30" Background="Blue" Click="blue_Click"/>
            <Button x:Name="clear" Width="100" Height="30" Content="Очистить" Margin="20,0,0,0" Click="clear_Click"/>

            <Button Content="Нажми ка!" Width="100" Height="30" Margin="20,0,0,0">
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Очистить холст" Click="clear_Click"/>
                        <Separator/>
                        <MenuItem Header="Выход" Click="exit_Click"/>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
        </StackPanel>

        <Canvas Background="AliceBlue" x:Name="DriwingCanvas" MouseDown="DrawingCanvas_MouseDown" MouseMove="DrawingCanvas_MouseMove" MouseUp="DrawingCanvas_MouseUp" Grid.Row="2"/>
    </Grid>
</Page>
