<Page x:Class="ISIP123_Solodov_WPF.Pages.ShoppingCartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ISIP123_Solodov_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="ShoppingCartPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="513*"/>
            <ColumnDefinition Width="287*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="21*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Корзиночка с покупочками" FontSize="16" HorizontalAlignment="Left" VerticalAlignment="Center" Height="22" Margin="299,0,0,0" Width="202"/>
        <StackPanel Grid.Row="1" VerticalAlignment="Bottom" Margin="10,0,0,0">
            <TextBlock x:Name="main" Text="7" Margin="0,10,0,0" FontSize="12" TextWrapping="Wrap"/>
            <TextBlock x:Name="finalPrice" Text="К оплате: " FontSize="16" Height="30"/>
        </StackPanel>
        <Button x:Name="TakeOrder" Content="Оформить заказ" Width="100" Grid.Row="2" HorizontalAlignment="Right" Margin="285,5,0,5" Click="TakeOrder_Click"/>
        <Button x:Name="GoBack" Content="↩" Width="30" Grid.Row="0" HorizontalAlignment="Left" Margin="10,5,0,5" Click="GoBack_Click"/>

        <Image Source="/Images/potihonku.jpg" Grid.Column="1" Grid.Row="1" Margin="20,20,20,20"/>
    </Grid>
</Page>
