<Page x:Class="ISIP123_Solodov_WPF.Pages.Page3_TotalPrice"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ISIP123_Solodov_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="400"
      Title="Page3_TotalPrice">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="199*"/>
            <ColumnDefinition Width="201*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="49*"/>
            <RowDefinition Height="49*"/>
            <RowDefinition Height="221*"/>
            <RowDefinition Height="49*"/>
            <RowDefinition Height="82*"/>
        </Grid.RowDefinitions>
        <TextBlock Margin="0,20,0,0" FontSize="16" Text="Салон Chevrolet 1964-1970" Grid.RowSpan="5" Grid.Row="0" TextAlignment="Center" Grid.ColumnSpan="2"/>
        <TextBlock Margin="0,10,0,0" FontSize="14" Text="Ваша комплектация:" TextAlignment="Center" TextWrapping="Wrap" Height="auto" Grid.Row="1" Grid.ColumnSpan="2" />
        <TextBlock x:Name="complectation" Margin="20,0,20,0" FontSize="14" Text="" Height="200" VerticalAlignment="Center" Grid.Row="2" Grid.ColumnSpan="2"/>
        <TextBlock x:Name="total" Margin="20,10,0,0" FontSize="14" Text="Итоговая стоимость:" TextAlignment="Left" Grid.Row="3" Grid.ColumnSpan="2" />
        <Button x:Name="ToBack" FontSize="14" Content="Назад" Height="35" Width="150" Grid.Row="4" Grid.Column="0" Click="ToBack_Click"/>
        <Button x:Name="ToNext" FontSize="14" Content="Оплатить" Height="35" Width="150" Grid.Row="4" Grid.Column="1" Click="ToNext_Click"/>
    </Grid>
</Page>
