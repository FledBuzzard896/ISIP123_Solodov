<Page x:Class="ISIP123_Solodov_WPF.Pages.Kinopoisk"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ISIP123_Solodov_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="Kinopoisk">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="13*"/>
            <RowDefinition Height="137*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <TextBlock Margin="15,0,0,0" Text="ФильмоПоиск" FontSize="16" VerticalAlignment="Center"/>
            <TextBox Margin="15,0,0,0" x:Name="searchBox" Height="25" Width="425" ToolTip="Введите название фильма/сериала" VerticalAlignment="Center" FontSize="14"/>
            <Button x:Name="searchBtn" Height="25" Width="25" Click="SearchBtnClick">
                <Image Source="/Image/glass.png"/>
            </Button>
            <ComboBox Margin="15,0,15,0" Height="25" Width="125" SelectionChanged="MyComboBox_SelectionChanged">
                <ComboBoxItem Content="По возрастанию"/>
                <ComboBoxItem Content="По убыванию"/>
                <ComboBoxItem Content="Рейтинг (↑)"/>
                <ComboBoxItem Content="Рейтинг (↓)"/>
            </ComboBox>
        </StackPanel>
        
        <Button x:Name="profile" Height="25" Width="25" HorizontalAlignment="Right" Margin="0,0,20,0" Grid.Row="0" Click="ProfileBtnClick">
            <Image Source="/Image/icon.png"/>
        </Button>

        <ListBox x:Name="Films_LB" MouseDoubleClick="MouseDoubleClick" ItemsSource="{Binding Path=movies}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Height="auto" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Row="1" Margin="20">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="10,0,10,10" Cursor="Hand">
                        <Image Width="150" Height="200" Source="{Binding Cover}"/>
                        <TextBlock HorizontalAlignment="Center" FontSize="14">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} ({1})">
                                    <Binding Path="Name"/>
                                    <Binding Path="Rating"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
    </Grid>
</Page>
