<Page x:Class="ISIP123_Solodov_WPF.Pages.Kinopoisk"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ISIP123_Solodov_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Kinopoisk">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="13*"/>
            <RowDefinition Height="137*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <TextBlock Margin="15,0,0,0" Text="ФильмоПоиск" FontSize="16" VerticalAlignment="Center"/>
            <TextBox Margin="15,0,0,0" x:Name="search" Height="25" Width="450" ToolTip="Введите название фильма/сериала" VerticalAlignment="Center" FontSize="14"/>
            <ComboBox Margin="15,0,15,0" Height="25" Width="125">
                <TextBlock Text="По возрастанию"/>
                <TextBlock Text="По убыванию"/>
            </ComboBox>
        </StackPanel>
        <Button x:Name="profile" Height="25" Width="25" HorizontalAlignment="Right" Margin="0,0,20,0" Grid.Row="0">
            <Image Source="/Image/icon.png"/>
        </Button>
        
    </Grid>
</Page>
