<Page x:Class="ISIP123_Solodov_WPF.Pages.FilmPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ISIP123_Solodov_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="FilmPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="173*"/>
            <ColumnDefinition Width="628*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="13*"/>
            <RowDefinition Height="137*"/>
        </Grid.RowDefinitions>

        <TextBlock Margin="15,0,0,0" Text="ФильмоПоиск" FontSize="16" VerticalAlignment="Center" Grid.ColumnSpan="2"/>
        <Button x:Name="profile" Height="25" Width="25" HorizontalAlignment="Right" Grid.Row="0" Grid.Column="1" Margin="0,0,20,0">
            <Image Source="/Image/icon.png"/>
        </Button>

        <StackPanel Grid.Row="1" Grid.Column="0" Margin="10" Orientation="Vertical">
            <Image Source="{Binding Cover}" Height="auto" VerticalAlignment="Top"/>
            <Button x:Name="BackBtn" Content="Назад" Width="100" Height="20" HorizontalAlignment="Center" Margin="0,0,0,0" />
        </StackPanel>

        
        <StackPanel Grid.Row="1" Grid.Column="1" Margin="10">
            <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" Width="auto"/>

            <Button x:Name="BuyTicket" Content="Купить билет" Width="100" Height="20" Margin="0,30,0,0" HorizontalAlignment="Left"/>

            <TextBlock Text="О фильме: " FontSize="14" FontWeight="Bold" Margin="0,30,0,5"/>
            <TextBlock Text="{Binding PremiereDate, StringFormat=Год производства: dd.MM.yyyy}" Margin="0,0,0,5"/>
            <TextBlock Text="{Binding Rating, StringFormat=Рейтинг: {0}}" Margin="0,0,0,5"/>
            <TextBlock x:Name="genryTextyGoggy" Margin="0,0,0,5"/>
            <TextBlock Text="Описание:" Margin="0,0,0,5"/>
            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,0,0,0"/>
        </StackPanel>
        
        <TextBlock x:Name="test" Text="" FontSize="30"/>


    </Grid>
</Page>
