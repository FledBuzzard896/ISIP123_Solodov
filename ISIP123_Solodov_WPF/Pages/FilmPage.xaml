<Page x:Class="ISIP123_Solodov_WPF.Pages.FilmPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ISIP123_Solodov_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="FilmPage">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="173*"/>
            <ColumnDefinition Width="628*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="13*"/>
            <RowDefinition Height="137*"/>
        </Grid.RowDefinitions>

        <TextBlock Margin="15,0,0,0" Text="ФильмоПоиск" FontSize="16" VerticalAlignment="Center" Grid.ColumnSpan="2"/>
        <Button x:Name="profile" Height="25" Width="25" HorizontalAlignment="Right" Grid.Row="0" Grid.Column="1" Margin="0,0,20,0">
            <Image Source="/Image/icon.png"/>
        </Button>

        <Image Source="{Binding cover}" Grid.Row="1" Grid.Column="0" Margin="10" Height="auto"/>
        <StackPanel Grid.Row="1" Grid.Column="1" Margin="10">
            <TextBlock Text="{Binding name}" FontSize="18" FontWeight="Bold" Width="auto" HorizontalAlignment="Center"/>
            <TextBlock Text="О фильме: " FontSize="14" FontWeight="Bold" Margin="0,30,0,5"/>
            <TextBlock Text="{Binding year}" Margin="0,0,0,5"/>
            <TextBlock Text="{Binding rating}" Margin="0,0,0,5"/>
            <TextBlock Text="{Binding genres}" Margin="0,0,0,5"/>
            <TextBlock Text="Описание:" Margin="0,0,0,5"/>
            <TextBlock Text="{Binding description}"/>
        </StackPanel>
    </Grid>
</Page>
