<Page x:Class="ISIP123_Solodov_WPF.Pages.Page5_EndForm"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ISIP123_Solodov_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="400"
      Title="Page5_EndForm">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="199*"/>
            <ColumnDefinition Width="201*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="51*"/>
            <RowDefinition Height="72*"/>
            <RowDefinition Height="141*"/>
            <RowDefinition Height="49*"/>
            <RowDefinition Height="86*"/>
            <RowDefinition Height="51*"/>
        </Grid.RowDefinitions>
        <TextBlock Margin="0,20,0,0" FontSize="16" Text="Салон Chevrolet 1964-1970" Grid.Row="0" TextAlignment="Center" Grid.ColumnSpan="2"/>
        <TextBlock Margin="20,10,0,0" FontSize="14" Text="Ваш заказ автомобиля успешно оформлен, чтобы мы могли предоставить вам дополнительную информацию, заполните форму ниже." TextWrapping="Wrap" Grid.Row="1" Grid.ColumnSpan="2"/>
        <StackPanel Margin="20,0,0,0" Grid.Row="2" Orientation="Vertical" Grid.ColumnSpan="2">
            <StackPanel  Orientation="Horizontal">
                <TextBlock Margin="0,10,0,0" FontSize="14" Text="Ваше ФИО: " VerticalAlignment="Center"/>
                <TextBox x:Name="FullName" Margin="25,10,0,0" FontSize="14" Text="" Width="200" TextChanged="FullName_TextChanged" />
            </StackPanel>
            <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                <TextBlock Margin="0,10,0,0" FontSize="14" Text="Ваш телефон: " VerticalAlignment="Center"/>
                <TextBox x:Name="PhoneNum" Margin="10,10,0,0" FontSize="14" Text="" Width="200" PreviewTextInput="TextBox_OnPreviewTextInput" TextChanged="PhoneNum_TextChanged"/>
            </StackPanel>
            <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                <TextBlock Margin="0,10,0,0" FontSize="14" Text="Адрес почты: " VerticalAlignment="Center"/>
                <TextBox x:Name="Mail" Margin="12,10,0,0" FontSize="14" Text="" Width="200" TextChanged="Mail_TextChanged"/>
            </StackPanel>
        </StackPanel>
        <Button x:Name="bttn" Content="Отправить" Grid.Row="3" Click="bttn_Click" Grid.ColumnSpan="2" Margin="125,9,125,6"/>
        <Button x:Name="ToBack" FontSize="14" Content="Назад" Grid.Row="5" Grid.Column="0" Click="ToBack_Click" Margin="25,6,25,6" />
    </Grid>
</Page>
