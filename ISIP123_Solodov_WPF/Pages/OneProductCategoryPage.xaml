<Page x:Class="ISIP123_Solodov_WPF.Pages.OneProductCategoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ISIP123_Solodov_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="OneProductCategoryPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding title, StringFormat='Категория: {0}'}" FontSize="18" Height="auto" HorizontalAlignment="Center" TextWrapping="Wrap" Grid.Row="0"/>
        <Button Content="Назад" Height="20" Width="75" Margin="15,0,0,0" HorizontalAlignment="Left" Click="Button_Click"/>
        <Grid Grid.Row="1" Margin="15,15,15,0">
            <ListBox x:Name="Products_LB" ItemsSource="{Binding Path=Products}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Height="auto" Width="auto" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="10,0,10,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Image Grid.Column="0" Source="{Binding image}" Width="150" Height="150"/>

                            <StackPanel Grid.Column="1" Orientation="Vertical" Margin="15,0,0,0">
                                <TextBlock Text="Описание:" FontSize="14" Height="auto" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding name}" FontSize="14" Height="auto" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Vertical" Margin="15,0,0,0" HorizontalAlignment="Right">
                                <TextBlock Text="Цена:" FontSize="14" Height="auto" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding price}" FontSize="14" Height="auto" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button x:Name="ADD" Content="Добавить в сборку" Height="25" Width="125" Grid.Column="3" Margin="15,0,0,0" HorizontalAlignment="Right" Click="AddBasePart"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="1" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
        </Grid>
        <Button x:Name="CheckSborka" Content="Проверить что в сборочке" Grid.Row="2" Margin="15,5,15,5" Width="auto" Height="20" Click="CheckSborka_Click"/>
    </Grid>
</Page>
