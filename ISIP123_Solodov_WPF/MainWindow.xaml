<Window x:Class="ISIP123_Solodov_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ISIP123_Solodov_WPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="79*"/>
            <RowDefinition Height="74*"/>
            <RowDefinition Height="97*"/>
            <RowDefinition Height="49*"/>
            <RowDefinition Height="43*"/>
            <RowDefinition Height="93*"/>
        </Grid.RowDefinitions>
        <!--Шапка-->
        <StackPanel Margin="0,0,0,68" Grid.RowSpan="2">
            <WrapPanel Margin="20,20,0,0" Height="auto" Grid.Row="0">
                <TextBlock FontSize="14" Text="Имя:" Height="auto" Width="auto"/>
                <TextBox x:Name="name" Margin="15,0,0,0" FontSize="14" Text="" Height="auto" Width="150"/>
            </WrapPanel>
            <WrapPanel Margin="20,10,0,0" Height="auto" Grid.Row="0">
                <TextBlock FontSize="14" Text="Телефон:" Height="auto" Width="auto"/>
                <TextBox x:Name="phone" Margin="15,0,0,0" FontSize="14" Text="" Height="auto" Width="122" PreviewTextInput="TextBox_OnPreviewTextInput"/>
            </WrapPanel>
        </StackPanel>
        <!--Способ оплаты-->
        <StackPanel Margin="20,20,0,3" Orientation="Vertical" Grid.Row="1">
            <TextBlock FontSize="14" Text="Способ оплаты:" Height="auto" Width="auto"/>
            <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                <RadioButton x:Name="btn1" GroupName="pay" FontSize="14" Content="Наличные" VerticalContentAlignment="Center"/>
                <RadioButton x:Name="btn2" Margin="15,0,0,0" GroupName="pay" FontSize="14" Content="Карта" VerticalContentAlignment="Center"/>
                <RadioButton x:Name="btn3" Margin="15,0,0,0" GroupName="pay" FontSize="14" Content="Онлайн" VerticalContentAlignment="Center"/>
            </StackPanel>
        </StackPanel>
        <!--Дополнительное-->
        <StackPanel Margin="20,20,0,0" Orientation="Vertical" Grid.Row="2">
            <TextBlock FontSize="14" Text="Дополонительно:" Height="auto" Width="auto"/>
            <CheckBox x:Name="box1" Margin="0,10,0,0" FontSize="14" Content="Подарочная упаковка (+100₽)" VerticalContentAlignment="Center" Click="box1_Checked"/>
            <CheckBox x:Name="box2" Margin="0,10,0,0" FontSize="14" Content="Срочная доставка (+200₽)" VerticalContentAlignment="Center" Click="box2_Checked"/>
        </StackPanel>
        <!--Количество-->
        <StackPanel Margin="20,20,0,0" Orientation="Horizontal" Grid.Row="3">
            <TextBlock FontSize="14" Text="Количество" Height="auto" Width="auto"/>
            <Slider Margin="15,0,0,0" Width="100" Minimum="1" Maximum="10" Value="1" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>
            <TextBlock x:Name="count" Margin="15,0,0,0" FontSize="14" Text="1 шт." Height="auto" Width="auto"/>
        </StackPanel>
        <!--Итог-->
        <TextBlock x:Name="total" Margin="20,20,0,0" FontSize="14" Text="Итого: 1000₽" Height="auto" Width="auto" Grid.Row="4"/>
        <Button Margin="0,20,0,0" Grid.Row="5" Width="150" Height="40" FontSize="14" Content="Оформить заказ" Click="Button_Click"/>
    </Grid>
</Window>
