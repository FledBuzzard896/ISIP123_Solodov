<Page x:Class="The_Binding_Of_Isaac_WPF.Pages.MenuNeutralRoom"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:The_Binding_Of_Isaac_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MenuNeutralRoom">

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="10" Orientation="Vertical">
            <TextBlock Text="Информация:" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="#ece0e4"/>
            <TextBlock x:Name="floorTxtBlck" Text="ТипЭтажа: этаж" FontSize="16" FontWeight="Bold" Foreground="#ece0e4" Margin="0,30,0,0"/>
            <TextBlock x:Name="hpTxtBlck" Text="HP: знач" FontSize="16" FontWeight="Bold" Foreground="#ece0e4" Margin="0,10,0,0"/>
            <TextBlock x:Name="damageTxtBlck" Text="Damage: знач" FontSize="16" FontWeight="Bold" Foreground="#ece0e4" Margin="0,10,0,0"/>
            <TextBlock x:Name="defenceTxtBlck" Text="Defence: знач" FontSize="16" FontWeight="Bold" Foreground="#ece0e4" Margin="0,10,0,0"/>
            <Image Source="/Images/IsaacLike.png" Margin="0,15,0,0"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="20" VerticalAlignment="Center">
            <!-- <Button x:Name="UseItem" Content="Использовать предмет" Width="150" Height="25" FontWeight="Bold" Margin="0,0,0,15" Click="UseItem_Click"/> -->
            <Button x:Name="GoNextRoom" Content="Зайти в комнату" Width="200" Height="25" FontWeight="Bold" FontSize="16" Background="#ece0e4" Click="GoNextRoom_Click"/>
        </StackPanel>
        <StackPanel Orientation="Vertical" Margin="10" Grid.Column="2">
            <TextBlock Text="Инвентарь:" HorizontalAlignment="Center" FontSize="20" Foreground="#ece0e4" FontWeight="Bold"/>
            <ListBox x:Name="ToolBar" Grid.Row="1" Margin="5" ItemsSource="{Binding Path=inventory}" ScrollViewer.HorizontalScrollBarVisibility="Hidden" ScrollViewer.VerticalScrollBarVisibility="Hidden" Background="Transparent" BorderThickness="0" Padding="0" MouseDoubleClick="UseItem_Click">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5" Orientation="Vertical">
                            <Image Source="{Binding imgUrl}" Width="35" Height="35" ToolTip="{Binding description}"/>
                            <!--<Button Content="Выбрать" FontWeight="Bold" Background="#ece0e4" Click="UseItem_Click"/> -->
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
        </StackPanel>
    </Grid>
</Page>
