<Page x:Class="The_Binding_Of_Isaac_WPF.Pages.Lore"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:The_Binding_Of_Isaac_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="Lore">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        
        <Image Source="/Images/Isaac.png" Width="200" Grid.RowSpan="2"/>
        <TextBlock Background="Black" Opacity="0.7" Grid.RowSpan="2" />
            
        <ScrollViewer VerticalScrollBarVisibility="Hidden">
            <TextBlock x:Name="lore" Text="" Foreground="White" FontSize="12" Grid.Row="0" Margin="15" TextWrapping="Wrap"/>
        </ScrollViewer>
        
        <Button x:Name="skipLoreBtn" Content="Далее" Width="55" Height="20" Grid.Row="1" HorizontalAlignment="Right" Margin="0,5,20,5" Background="DarkGray" Click="skipLoreBtn_Click"/>
    </Grid>
</Page>
