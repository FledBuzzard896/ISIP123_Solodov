<Page x:Class="The_Binding_Of_Isaac_WPF.Pages.GenerateFloor"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:The_Binding_Of_Isaac_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="GenerateFloor">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <TextBlock Background="Black" Grid.RowSpan="2"/>
        <StackPanel Grid.Row="0" Orientation="Vertical">
            <Image x:Name="IsaacNightmare" Width="400" Height="250"/>
            <Image x:Name="Isaac" Width="250" Height="150"/>
        </StackPanel>
        
        <Button x:Name="generateFloor" Content="Далее" Width="50" Height="20" FontWeight="Bold" HorizontalAlignment="Right" Margin="10" Grid.Row="1" Click="generateFloor_Click"/>
    </Grid>
</Page>
