<Page x:Class="The_Binding_Of_Isaac_WPF.Pages.MainMenu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:The_Binding_Of_Isaac_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="The Binding Of Isaac: Rebirth">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Image Grid.Row="0" Source="/Images/IsaacLogo.jpg"/>
        <Button x:Name="startBtn" Content="Начать игру" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1" Width="150" Height="50" FontSize="20" FontWeight="Bold" Background="#ece0e4" Click="startBtn_Click"/>
    </Grid>
</Page>
