<Page x:Class="The_Binding_Of_Isaac_WPF.Pages.CharacterSelection"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:The_Binding_Of_Isaac_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="CharacterSelection">

    <Grid>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Кто же я?" Margin="10" FontSize="25" FontWeight="Bold" HorizontalAlignment="Center" Grid.ColumnSpan="3" TextWrapping="Wrap"/>

        <!-- Магдалина -->
        <Grid Margin="15,5,5,5" Grid.Row="1" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Image Source="/Images/MiniCharacters/MiniMagdaline.png" Margin="15" Height="200" Grid.Row="0"/>
            <StackPanel Grid.Row="1" Margin="35">
                <TextBlock Text="HP:       |  |  |  |" FontSize="20" FontWeight="Bold"/>
                <TextBlock Text="DMG:   |  | " FontSize="20" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
        <Button x:Name="MagdalineBtn" Content="Выбрать Магдалину" Grid.Row="2" Grid.Column="0" Margin="10" Width="150" Height="25" FontWeight="Bold" Background="#ece0e4" Click="MagdalineBtn_Click"/>
        
        <!-- Айзек -->
        <Grid Margin="15,5,5,5" Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Image Source="/Images/MiniCharacters/MiniIsaac.png" Margin="15" Height="200" Grid.Row="0"/>
            <StackPanel Grid.Row="1" Margin="35">
                <TextBlock Text="HP:       |  |  |" FontSize="20" FontWeight="Bold"/>
                <TextBlock Text="DMG:   |  | " FontSize="20" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
        <Button x:Name="IsaacBtn" Content="Выбрать Айзека" Grid.Row="2" Grid.Column="1" Margin="10" Width="150" Height="25" FontWeight="Bold" Background="#ece0e4" Click="IsaacBtn_Click"/>

        <!-- Каин -->
        <Grid Margin="15,5,5,5" Grid.Row="1" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Image Source="/Images/MiniCharacters/MiniKain.png" Margin="15" Height="200" Grid.Row="0"/>
            <StackPanel Grid.Row="1" Margin="35">
                <TextBlock Text="HP:       |  |" FontSize="20" FontWeight="Bold"/>
                <TextBlock Text="DMG    |  |  |" FontSize="20" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
        <Button x:Name="KainBtm" Content="Выбрать Каина" Grid.Row="2" Grid.Column="2" Margin="10" Width="150" Height="25" FontWeight="Bold" Background="#ece0e4" Click="KainBtm_Click"/>
    </Grid>
</Page>
