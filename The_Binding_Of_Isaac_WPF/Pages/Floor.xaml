<Page x:Class="The_Binding_Of_Isaac_WPF.Pages.Floor"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:The_Binding_Of_Isaac_WPF.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Floor">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="4*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Grid x:Name="StatsGrid" Margin="10" Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Статистика" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Grid.Row="0" Grid.ColumnSpan="2"/>
            <!-- Здоровье Персонажа -->
            <Image Source="/Images/Icons/HealthIcon.png" Margin="30,0,5,5" Width="50" VerticalAlignment="Bottom" Grid.Row="1" Grid.Column="0"/>
            <TextBlock x:Name="hpBar" Text="test" Grid.Row="1" Grid.Column="1" VerticalAlignment="Bottom" Margin="5,0,0,15" FontSize="16" FontWeight="Bold"/>
            <!-- Урон Персонажа -->
            <Image Source="/Images/Icons/DamageIcon.png"  Margin="30,0,5,0" Width="50" Grid.Row="2" Grid.Column="0"/>
            <TextBlock x:Name="dmgBar" Text="test" Grid.Row="2" Grid.Column="1" Margin="5,0,0,0" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
            <!-- Защита Персонажа --> 
            <Image Source="/Images/Icons/DefenceIcon.png"  Margin="30,0,5,0" Width="50" VerticalAlignment="Top" Grid.Row="3" Grid.Column="0"/>
            <TextBlock x:Name="dfncBar" Text="test" Grid.Row="3" Grid.Column="1" Margin="5,15,0,0" VerticalAlignment="Top" FontSize="16" FontWeight="Bold"/>
        </Grid>
        
        <Grid x:Name="FieldGrid" Margin="10" Grid.Row="0" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Враг -->
            <Image x:Name="Enemy" Grid.RowSpan="2" Grid.ColumnSpan="2" Margin="10"/>
            <!-- Здоровье врага -->
            <TextBlock x:Name="EnemyHealthBar" Text="" Margin="10" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Grid.Row="2" Grid.Column="0"/>
            <!-- Урон врага -->
            <TextBlock x:Name="EnemyDamageBar" Text="" Margin="10" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Grid.Row="2" Grid.Column="1"/>

            <!-- Предмет -->
            <Image x:Name="Item" Width="50" Height="50" VerticalAlignment="Bottom" Grid.Row="0" Grid.ColumnSpan="2" Margin="10,10,10,0"/>
            <Image x:Name="Chest" Grid.Row="1" Grid.ColumnSpan="2" Margin="10,0,10,10"/>
            <!-- Описание предмета -->
            <ScrollViewer VerticalScrollBarVisibility="Hidden" Grid.Row="2" Grid.ColumnSpan="2">
                <TextBlock x:Name="ItemDescriptionBar" Text="" Margin="10" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Grid>

        <Grid x:Name="ToolBarGrid" Margin="10" Grid.Row="0" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Инвентарь" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Row="0"/>
            <ListBox x:Name="ToolBar" Grid.Row="1" Margin="5" ItemsSource="{Binding Path=sborochka_items}" ScrollViewer.HorizontalScrollBarVisibility="Hidden" ScrollViewer.VerticalScrollBarVisibility="Hidden" Background="Transparent" BorderThickness="0" Padding="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5" Orientation="Vertical">
                            <Image Source="{Binding inventory}" Width="35" Height="35"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
        </Grid>

        <TextBlock x:Name="Info" Text="" Margin="5" Grid.Row="1" Grid.Column="0"/>

        <StackPanel x:Name="Buttons" Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="PozitiveBtn" Content="Атаковать/Взять предмет" Width="125" Height="30" Margin="0,0,20,0" Click="PozitiveBtn_Click"/>
            <Button x:Name="NegativeBtn" Content="Уклониться/Пропустить предмет" Width="125" Height="30" Click="NegativeBtn_Click"/>
        </StackPanel>
    </Grid>
</Page>
