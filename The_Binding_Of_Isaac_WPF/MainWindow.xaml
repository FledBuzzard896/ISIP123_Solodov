<Window x:Class="The_Binding_Of_Isaac_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:The_Binding_Of_Isaac_WPF"
        mc:Ignorable="d"
        Title="The Binding Of Isaac: Rebirth" Height="500" Width="800"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid x:Name="RootGrid" Background="#cbc0bc">

        <Image x:Name="BasementBackImage" 
           Source="/Images/Background/BasementBack.png" 
           Stretch="Fill" 
           Visibility="Hidden"/>

        <Image x:Name="DepthBackImage" 
           Source="/Images/Background/DepthsBack.png" 
           Stretch="Fill" 
           Visibility="Hidden"/>

        <Frame x:Name="MainFrame" Source="Pages/MainMenu.xaml" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
